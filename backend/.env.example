# FinCoach Backend Environment Variables
# Copy to .env and fill in your values

APP_NAME=FinCoach
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Database — Supabase Postgres (or local)
# For local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/fincoach
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fincoach

# Supabase (optional for MVP — used for auth later)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI / OpenRouter — for LLM categorization & insights
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/v1
OPENROUTER_MODEL=gpt-4o-mini

# File encryption key — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FILE_ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000"]

